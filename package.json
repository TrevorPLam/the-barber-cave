{
  "name": "trills-barber-cave",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "test": "vitest",
    "test:watch": "vitest --watch",
    "test:coverage": "vitest --coverage",
    "test:ui": "vitest --ui",
    "storybook": "npx storybook dev -p 6006",
    "build-storybook": "npx storybook build",
    "test:visual": "chromatic --exit-zero-on-changes",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:performance": "lhci autorun",
    "test:performance:collect": "lhci collect",
    "docs:build": "typedoc",
    "docs:serve": "npx serve docs/api",
    "docs:watch": "typedoc --watch",
    "docs:clean": "rm -rf docs/api",
    "prepare": "husky",
    "db:generate": "drizzle-kit generate",
    "db:push": "drizzle-kit push",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio",
    "db:seed": "tsx src/data/seed.ts",
    "db:rollback": "tsx -e \"import('@/lib/migrations').then(m => m.migrationManager.rollback().then(tag => console.log(tag ? 'Rolled back: ' + tag : 'Nothing to roll back')))\"",
    "db:status": "tsx -e \"import('@/lib/migrations').then(m => m.migrationManager.status().then(s => s.forEach(r => console.log(r.applied ? '✅' : r.rolledBack ? '↩️' : '⏳', r.tag))))\"",
    "bundle:check": "node scripts/check-bundle-size.mjs",
    "bundle:check:verbose": "VERBOSE=true node scripts/check-bundle-size.mjs"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx}": [
      "eslint --fix --max-warnings 0",
      "eslint --max-warnings 0"
    ]
  },
  "dependencies": {
    "@sentry/nextjs": "^10.42.0",
    "@supabase/supabase-js": "^2.98.0",
    "@testing-library/dom": "^10.4.1",
    "@types/bcryptjs": "^2.4.6",
    "@types/dompurify": "^3.0.5",
    "bcryptjs": "^3.0.3",
    "clsx": "^2.1.1",
    "dompurify": "^3.3.1",
    "drizzle-kit": "^0.31.9",
    "drizzle-orm": "^0.45.1",
    "lucide-react": "^0.576.0",
    "next": "16.1.6",
    "next-auth": "^4.24.13",
    "next-axiom": "^1.10.0",
    "next-logger": "^5.0.2",
    "pino": "^10.3.1",
    "postgres": "^3.4.8",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "tailwind-merge": "^3.5.0",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@axe-core/react": "^4.11.1",
    "@chromatic-com/storybook": "^5.0.1",
    "@lhci/cli": "^0.15.1",
    "@next/bundle-analyzer": "^16.1.6",
    "@playwright/test": "^1.58.2",
    "@storybook/addon-a11y": "^10.2.14",
    "@storybook/addon-docs": "^10.2.14",
    "@storybook/builder-vite": "^10.2.14",
    "@storybook/react": "^10.2.14",
    "@storybook/react-vite": "^10.2.14",
    "@tailwindcss/postcss": "^4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^5.1.4",
    "@vitest/coverage-v8": "^4.0.18",
    "@vitest/ui": "^4.0.18",
    "babel-plugin-react-compiler": "1.0.0",
    "canvas": "^3.2.1",
    "chromatic": "^15.2.0",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "eslint-plugin-jsdoc": "^50.6.1",
    "eslint-plugin-storybook": "10.2.14",
    "husky": "^9.1.7",
    "jsdom": "^28.1.0",
    "knip": "^5.85.0",
    "lint-staged": "^15.2.11",
    "storybook": "^10.2.14",
    "tailwindcss": "^4",
    "typedoc": "^0.28.17",
    "typedoc-plugin-markdown": "^4.10.0",
    "typescript": "^5.9.3",
    "vite": "^7.3.1",
    "vitest": "^4.0.18",
    "vitest-axe": "^0.1.0"
  }
}
